{
  "name": "premium-leadgen",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram + MAX lead generation ecosystem (Supabase + n8n + Vercel)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'add eslint when needed'",
    "supabase:link": "supabase link --project-ref \"$SUPABASE_PROJECT_REF\"",
    "supabase:push": "supabase db push",
    "supabase:diff": "supabase db diff -f new_migration",
    "telegram:set-webhook": "bash scripts/set-telegram-webhook.sh",
    "max:set-webhook": "bash scripts/set-max-webhook.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vercel/node": "^3.2.0",
    "typescript": "^5.4.5"
  }
}
