# =============================================================================
# Premium — переменные окружения
# Скопируйте в .env.local для разработки и пропишите в Vercel Project Settings
# для production / preview / development. НЕ коммитьте .env / .env.local!
# =============================================================================

# ---------- Supabase ---------------------------------------------------------
# URL проекта (https://<project-ref>.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co
# Anonymous key — клиентский, можно вставлять в браузер (NEXT_PUBLIC_*).
SUPABASE_ANON_KEY=eyJhbGci...your-anon-key
# Service role key — ТОЛЬКО на сервере (Vercel Functions, n8n).
# НИКОГДА не отдавать в браузер. Обходит RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key
# Project ref — нужен для Supabase CLI (supabase link --project-ref).
SUPABASE_PROJECT_REF=your-project-ref
# Пароль БД (для прямого подключения и миграций).
SUPABASE_DB_PASSWORD=super-secret-password
# Direct Postgres connection string (для n8n Postgres ноды).
# Формат: postgres://postgres:<password>@db.<ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=postgres://postgres:PASSWORD@db.your-project-ref.supabase.co:5432/postgres

# ---------- Telegram ---------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456789:AAH...your-telegram-bot-token
# Любая строка (генерируйте openssl rand -hex 32). Передаётся в setWebhook
# как secret_token и проверяется в обработчике.
TELEGRAM_WEBHOOK_SECRET=replace-with-random-32-bytes
# Chat ID, куда бот шлёт уведомления о новых лидах (вам).
TELEGRAM_OWNER_CHAT_ID=123456789

# ---------- MAX --------------------------------------------------------------
# Токен бота из MAX MasterBot.
MAX_BOT_TOKEN=your-max-bot-token
# Базовый URL MAX Bot API (по умолчанию см. документацию платформы).
MAX_API_URL=https://botapi.max.ru
# Секрет для верификации входящих вебхуков MAX.
MAX_WEBHOOK_SECRET=replace-with-random-32-bytes

# ---------- BotHelp / Botmother / Umnico (опционально) ----------------------
# Если используете готовую платформу для MAX как промежуточное звено.
BOTHELP_API_TOKEN=
BOTHELP_WEBHOOK_SECRET=
UMNICO_API_TOKEN=

# ---------- n8n --------------------------------------------------------------
# Базовый URL n8n (https://n8n.example.com).
N8N_BASE_URL=https://n8n.your-domain.ru
# Полные URL вебхуков n8n для разных сценариев.
N8N_WEBHOOK_URL=https://n8n.your-domain.ru/webhook/lead-events
N8N_TELEGRAM_WEBHOOK_URL=https://n8n.your-domain.ru/webhook/telegram
N8N_MAX_WEBHOOK_URL=https://n8n.your-domain.ru/webhook/max
# Bearer token (HMAC), которым Vercel подписывает запросы в n8n.
N8N_INBOUND_SECRET=replace-with-random-32-bytes

# ---------- Общее ------------------------------------------------------------
PROJECT_ENV=development            # development | preview | production
LOG_LEVEL=info                      # debug | info | warn | error
DEFAULT_TIMEZONE=Asia/Omsk
DEFAULT_CITY=Омск

# ---------- Vercel-only (заполняется автоматически) -------------------------
# VERCEL_URL, VERCEL_ENV — выставляются Vercel'ом, использовать как readonly.
